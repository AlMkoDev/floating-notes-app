{
  "name": "floating-notes-app",
  "author": "AlMkoDev",
  "version": "1.1.0",
  "description": "Floating Notes App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.floating.notes",
    "productName": "Floating Notes",

    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "differentialPackage": true
    },

    "nsisWeb": false,

    "publish": [
      {
        "provider": "github",
        "owner": "AlMkoDev",
        "repo": "floating-notes-app",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "html-docx-js": "^0.3.1",
    "pdfkit": "^0.15.0",
    "quill": "^2.0.0"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^24.0.0"
  }
}